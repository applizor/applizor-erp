ency(totalTax)}</span>\n                                                    </div>\n                                                    <div className=\"pl-4 border-l-2 border-emerald-100 space-y-1 py-1 bg-emerald-50/30 rounded-r ml-1\">\n                                                        {Object.entries(taxBreakdown).map(([key, amount]) => (\n                                                            <div key={key} className=\"flex justify-between text-[10px] font-bold text-emerald-700\">\n                                                                <span className=\"italic\">{key}:</span>\n                                                                <span>{formatCurrency(amount as number)}</span>\n                                                            </div>\n                                                        ))}\n                                                    </div>\n                                                </>\n                                            );\n                                        })", "is_member_call": false, "source_file": "/Users/arun/Documents/applizor-softech-erp/frontend/app/(main)/invoices/[id]/page.tsx", "source_location": "L497"}, {"caller_nid": "id_page_invoicedetailpage", "callee": "Number", "is_member_call": false, "source_file": "/Users/arun/Documents/applizor-softech-erp/frontend/app/(main)/invoices/[id]/page.tsx", "source_location": "L519"}, {"caller_nid": "id_page_invoicedetailpage", "callee": "formatCurrency", "is_member_call": false, "source_file": "/Users/arun/Documents/applizor-softech-erp/frontend/app/(main)/invoices/[id]/page.tsx", "source_location": "L522"}, {"caller_nid": "id_page_invoicedetailpage", "callee": "formatCurrency", "is_member_call": false, "source_file": "/Users/arun/Documents/applizor-softech-erp/frontend/app/(main)/invoices/[id]/page.tsx", "source_location": "L528"}, {"caller_nid": "id_page_invoicedetailpage", "callee": "map", "is_member_call": true, "source_file": "/Users/