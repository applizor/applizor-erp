ation": "L31"}, {"caller_nid": "id_page_invoicedetailpage", "callee": "useState", "is_member_call": false, "source_file": "/Users/arun/Documents/applizor-softech-erp/frontend/app/(main)/invoices/[id]/page.tsx", "source_location": "L32"}, {"caller_nid": "id_page_invoicedetailpage", "callee": "useEffect", "is_member_call": false, "source_file": "/Users/arun/Documents/applizor-softech-erp/frontend/app/(main)/invoices/[id]/page.tsx", "source_location": "L34"}, {"caller_nid": "id_page_invoicedetailpage", "callee": "(() => {\n        const breakdown: Record<string, number> = {};\n        let calculatedSubtotal = 0;\n        let calculatedItemDiscount = 0;\n\n        invoice.items.forEach((item: any) => {\n            const quantity = Number(item.quantity) || 0;\n            const rate = Number(item.rate) || 0;\n            const itemGross = quantity * rate;\n            const discountPercent = Number(item.discount || 0);\n            const itemDiscAmount = itemGross * (discountPercent / 100);\n            const taxableAmount = itemGross - itemDiscAmount;\n\n            calculatedSubtotal += itemGross;\n            calculatedItemDiscount += itemDiscAmount;\n\n            if (item.appliedTaxes && item.appliedTaxes.length > 0) {\n                item.appliedTaxes.forEach((tax: any) => {\n                    const key = `${tax.name} @${Number(tax.percentage)}%`;\n                    breakdown[key] = (breakdown[key] || 0) + Number(tax.amount);\n                });\n            } else if (Number(item.taxRate) > 0) {\n                // Fallback\n                const taxAmount = taxableAmount * (Number(item.taxRate) / 100);\n                const key = `Tax @${Number(item.taxRate)}%`;\n                breakdown[key] = (breakdown[key] || 0) + taxAmount;\n            }\n        });\n\n        const totalTaxCalc = Object.values(breakdown).reduce((a, b) => a + b, 0);\n        return {\n            taxBreakdown: breakdown,\n            subtotal: calculatedSubtotal,\n            totalTax: totalTaxCalc,\n            totalItemDiscount: calculatedItemDiscount\n        };\n    })", "is_member_call": false, "source_file": "/Users/arun/Documents/applizor-softech-erp/frontend/app/(main)/invoices/[id]/page.tsx", "source_location": "L194"}, {"caller_nid": "id_page_invoicedetailpage", "callee": "toLocaleString", "is_member_call": true, "source_file": "/Users/arun/Documents/applizor-softech-erp/frontend/app/(main)/invoices/[id]/page.tsx", "source_location": "L352"}, {"caller_nid": "id_page_invoicedetailpage", "callee": "toLocaleDateString", "is_member_call": true, "source_file": "/Users/arun/Documents/applizor-softech-erp/frontend/app/(main)/invoices/[id]/page.tsx", "source_location": "L380"}, {"caller_nid": "id_page_invoicedetailpage", "callee": "toLocaleDateString", "is_member_call": true, "source_file": "/Users/arun/Documents/applizor-softech-erp/frontend/app/(main)/invoices/[id]/page.tsx", "source_location": "L385"}, {"caller_nid": "id_page_invoicedetailpage", "callee": "formatCurrency", "is_member_call": false, "source_file": "/Users/arun/Documents/applizor-softech-erp/frontend/app/(main)/invoices/[id]/page.tsx", "source_location": "L411"}, {"caller_nid": "id_page_invoicedetailpage", "callee": "formatCurrency", "is_member_call": false, "source_file": "/Users/arun/Documents/applizor-softech-erp/frontend/app/(main)/invoices/[id]/page.tsx", "source_location": "L415"}, {"caller_nid": "id_page_invoicedetailpage", "callee": "Number", "is_member_call": false, "source_file": "/Users/arun/Documents/applizor-softech-erp/frontend/app/(main)/invoices/[id]/page.tsx", "source_location": "L419"}, {"caller_nid": "id_page_invoicedetailpage", "callee": "Number", "is_member_call": false, "source_file": "/Users/arun/Documents/applizor-softech-erp/frontend/app/(main)/invoices/[id]/page.tsx", "source_location": "L419"}, {"caller_nid": "id_page_invoicedetailpage", "callee": "formatCurrency", "is_member_call": false, "source_file": "/Users/arun/Documents/applizor-softech-er